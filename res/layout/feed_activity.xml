<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:background="@color/background_color" android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:background="@color/background_color" android:layout_width="fill_parent" android:layout_height="fill_parent">
        <androidx.appcompat.widget.Toolbar android:id="@id/toolbar_feed" android:layout_width="fill_parent" android:layout_height="?android:actionBarSize">
            <TextView android:id="@id/tv_toolbar_feed" android:layout_width="fill_parent" android:layout_height="wrap_content" android:text="@string/my_feed" style="@style/UptodownToolbarStyle" />
        </androidx.appcompat.widget.Toolbar>
